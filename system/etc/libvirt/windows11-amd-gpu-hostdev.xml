<!--
  AMD RX 7900 XTX (03:00.0) + HDMI/DP audio (03:00.1)

  Install VBIOS once: sudo windows11-dump-vbios

  BIOS for passthrough: IOMMU + Above 4G Decoding enabled.
  RX 7900 XTX black-screen fix: keep explicit VBIOS file, but hide ROM BAR.

  NOTE: <rom> must be a direct child of <hostdev>, NOT inside <driver>.
-->
<hostdev mode="subsystem" type="pci" managed="yes">
  <driver name="vfio"/>
  <source>
    <address domain="0x0000" bus="0x03" slot="0x00" function="0x0"/>
  </source>
  <rom bar="off" file="/var/lib/libvirt/vbios/rx7900xtx.rom"/>
</hostdev>
<hostdev mode="subsystem" type="pci" managed="yes">
  <source>
    <address domain="0x0000" bus="0x03" slot="0x00" function="0x1"/>
  </source>
</hostdev>
