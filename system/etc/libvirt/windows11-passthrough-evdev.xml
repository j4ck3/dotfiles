<!--
  Evdev inputs for passthrough gaming.
  Uses stable /dev/input/by-id paths; globs match any dongle serial.

  Keyboard: Keychron Q1 (both HID interfaces — QMK often uses if02 for keys)
  Mouse: Finalmouse UltralightX dongle / ZeroMouse (361d:0100)

  Merged by: sudo windows11-mode passthrough-evdev
             windows11-stealth-tune
  Missing paths are skipped automatically.
-->
<input type="evdev">
  <source dev="/dev/input/by-id/usb-Keychron_Keychron_Q1-event-kbd" grab="all" repeat="on" grabToggle="shift-shift"/>
</input>
<input type="evdev">
  <source dev="/dev/input/by-id/usb-Keychron_Keychron_Q1-if02-event-kbd" grab="all" repeat="on" grabToggle="shift-shift"/>
</input>
<input type="evdev">
  <source dev="/dev/input/by-id/usb-Finalmouse_*-event-mouse" grab="all" grabToggle="shift-shift"/>
</input>
<input type="evdev">
  <source dev="/dev/input/by-id/usb-ZeroMouse_*-event-mouse" grab="all" grabToggle="shift-shift"/>
</input>
