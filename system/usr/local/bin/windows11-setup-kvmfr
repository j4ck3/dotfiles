#!/usr/bin/env bash
# Build and load the Looking Glass kvmfr kernel module (no AUR package required).
set -euo pipefail

LG_REF="${LG_REF:-B7}"
BUILD_DIR="${BUILD_DIR:-/usr/local/src/looking-glass-kvmfr}"
MODULE_SIZE_MB="${MODULE_SIZE_MB:-64}"
# Build for a non-running kernel (e.g. 7.0.5-2-cachyos) when headers match that version.
KERNEL_TARGET="${KERNEL_TARGET:-$(uname -r)}"

if [[ "${EUID}" -ne 0 ]]; then
  echo "Run as root: sudo $0" >&2
  exit 1
fi

for dep in dkms git gcc make; do
  command -v "${dep}" >/dev/null || {
    echo "Missing ${dep}. Install: sudo pacman -S dkms git base-devel" >&2
    exit 1
  }
done

kernel_headers_dir() {
  local kver="$1"
  if [[ -d "/usr/lib/modules/${kver}/build" ]]; then
    echo "/usr/lib/modules/${kver}/build"
    return 0
  fi
  return 1
}

print_headers_fix() {
  local running
  running="$(uname -r)"
  echo "Running kernel:  ${running}" >&2
  if pacman -Q linux-cachyos-headers &>/dev/null; then
    echo "Headers package: $(pacman -Q linux-cachyos-headers)" >&2
  fi
  echo "" >&2
  echo "Fix (pick one):" >&2
  local kbase cached
  kbase="${running%-cachyos}"
  cached="$(compgen -G "/var/cache/pacman/pkg/linux-cachyos-headers-${kbase}*.pkg.tar.zst" 2>/dev/null | head -1 || true)"
  if [[ -n "${cached}" ]]; then
    echo "  A) Match headers to current kernel (no reboot):" >&2
    echo "     sudo pacman -U ${cached}" >&2
  fi
  echo "  B) Upgrade kernel to match installed headers, then reboot:" >&2
  echo "     sudo pacman -S linux-cachyos linux-cachyos-headers" >&2
  echo "     # pick 7.0.5-2 (or newest) in Limine, then re-run this script" >&2
  if kernel_headers_dir "7.0.5-2-cachyos" >/dev/null 2>&1 && [[ "${running}" != "7.0.5-2-cachyos" ]]; then
    echo "  C) Build kvmfr for 7.0.5 now, reboot into that kernel later:" >&2
    echo "     sudo KERNEL_TARGET=7.0.5-2-cachyos $0" >&2
  fi
}

if ! kernel_headers_dir "${KERNEL_TARGET}" >/dev/null; then
  echo "ERROR: No kernel headers for ${KERNEL_TARGET}" >&2
  print_headers_fix
  exit 1
fi

if [[ -f /dev/kvmfr0 && ! -c /dev/kvmfr0 ]]; then
  echo "Removing stale regular file /dev/kvmfr0"
  rm -f /dev/kvmfr0
fi

install -d -m 0755 "${BUILD_DIR}"
if [[ ! -d "${BUILD_DIR}/.git" ]]; then
  git clone --recursive --depth 1 --branch "${LG_REF}" \
    https://github.com/gnif/LookingGlass.git "${BUILD_DIR}"
else
  git -C "${BUILD_DIR}" fetch --depth 1 origin "${LG_REF}" 2>/dev/null || true
  git -C "${BUILD_DIR}" checkout -f "${LG_REF}" 2>/dev/null || true
  git -C "${BUILD_DIR}" submodule update --init --recursive
fi

MODULE_DIR="${BUILD_DIR}/module"
[[ -f "${MODULE_DIR}/dkms.conf" ]] || {
  echo "Missing ${MODULE_DIR}/dkms.conf" >&2
  exit 1
}

KVMFR_VER="$(
  grep '^PACKAGE_VERSION=' "${MODULE_DIR}/dkms.conf" | head -1 | cut -d'"' -f2
)"
[[ -n "${KVMFR_VER}" ]] || {
  echo "Could not read PACKAGE_VERSION from dkms.conf" >&2
  exit 1
}

echo "Installing kvmfr ${KVMFR_VER} for kernel ${KERNEL_TARGET} ..."
dkms remove -m kvmfr -v B7 --all 2>/dev/null || true
dkms remove -m kvmfr -v "${KVMFR_VER}" --all 2>/dev/null || true

(
  cd "${MODULE_DIR}"
  dkms install --force -k "${KERNEL_TARGET}" .
)

install -m 0644 /dev/stdin /etc/modprobe.d/kvmfr.conf <<EOF
options kvmfr static_size_mb=${MODULE_SIZE_MB}
EOF
install -m 0644 /dev/stdin /etc/modules-load.d/kvmfr.conf <<EOF
kvmfr
EOF

running="$(uname -r)"
if [[ "${KERNEL_TARGET}" != "${running}" ]]; then
  echo ""
  echo "kvmfr built for ${KERNEL_TARGET} (you are running ${running})."
  echo "Reboot into ${KERNEL_TARGET}, then run:"
  echo "  sudo modprobe kvmfr"
  echo "  sudo windows11-mode passthrough"
  exit 0
fi

modprobe -r kvmfr 2>/dev/null || true
modprobe kvmfr

if [[ ! -c /dev/kvmfr0 ]]; then
  echo "ERROR: kvmfr loaded but /dev/kvmfr0 is not a character device." >&2
  dmesg | grep -i kvmfr | tail -5 || true
  exit 1
fi

if [[ -f /etc/udev/rules.d/99-kvmfr.rules ]]; then
  udevadm control --reload-rules
  udevadm trigger --subsystem-match=kvmfr 2>/dev/null || true
fi

echo "OK: $(ls -l /dev/kvmfr0)  (kvmfr-${KVMFR_VER} on ${KERNEL_TARGET})"
echo "  sudo windows11-mode passthrough"
