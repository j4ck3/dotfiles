#!/usr/bin/env bash
# Start the stealth clone with the same safety checks as windows11-start.
set -euo pipefail

export DOMAIN="${DOMAIN:-windows11-stealth}"
export CONNECT_URI="${CONNECT_URI:-qemu:///system}"
export FORCE_STOP="${FORCE_STOP:-/usr/local/bin/windows11-stealth-force-stop}"

NVRAM="/var/lib/libvirt/qemu/nvram/windows11-stealth_VARS.fd"
GOOD_CACHE="${HOME}/.cache/windows11-stealth-debug/windows11-stealth_VARS.fd.good"

verify_nvram() {
  [[ -f "${NVRAM}" ]] || {
    echo "Missing ${NVRAM}. Run: sudo windows11-stealth-fix-boot" >&2
    exit 1
  }
  if [[ -f "${GOOD_CACHE}" ]] && ! cmp -s "${NVRAM}" "${GOOD_CACHE}"; then
    echo "NVRAM no longer matches known-good boot copy." >&2
    echo "  live:  ${NVRAM}" >&2
    echo "  good:  ${GOOD_CACHE}" >&2
    echo "Fix: sudo windows11-stealth-fix-boot" >&2
    exit 1
  fi
}

verify_nvram
exec /usr/local/bin/windows11-start "$@"
