#!/usr/bin/env bash
# mirror5.krfoss.org answers HTTP 200 with an HTML welcome page (~7 KiB) for
# package URLs. Pacman saves that as the .pkg.tar.zst and PGP check fails.
set -euo pipefail

MIRRORLISTS=(
  /etc/pacman.d/cachyos-mirrorlist
  /etc/pacman.d/cachyos-v3-mirrorlist
  /etc/pacman.d/cachyos-v4-mirrorlist
)

for f in "${MIRRORLISTS[@]}"; do
  [[ -f "$f" ]] || continue
  if grep -q '^Server = https://mirror5\.krfoss\.org' "$f"; then
    sed -i '/^Server = https:\/\/mirror5\.krfoss\.org/d' "$f"
    echo "Removed mirror5.krfoss.org from $f"
  else
    echo "Already clean: $f"
  fi
done

rm -f /var/cache/pacman/pkg/libsysprof-capture-50.0-2.1-x86_64_v3.pkg.tar.zst
rm -f /var/cache/pacman/pkg/libsysprof-capture-50.0-2.1-x86_64_v3.pkg.tar.zst.sig

echo "Next: sudo pacman -Syu"
