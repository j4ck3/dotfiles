#!/usr/bin/env bash
# Backup / check / repair the windows11 qcow2 (owned by libvirt-qemu).
set -euo pipefail

DISK="${DISK:-/home/jacke/.local/share/libvirt/images/windows11.qcow2}"
BACKUP="${BACKUP:-${DISK}.bak}"

export LC_ALL=C
export LANG=C

usage() {
  cat <<EOF
Usage: ${0##*/} <command>

Commands:
  backup    Copy disk to ${BACKUP} (needs root)
  check     qemu-img check -r all
  info      qemu-img info

Example:
  sudo ${0##*/} backup
  sudo ${0##*/} check
EOF
}

require_root() {
  [[ "${EUID}" -eq 0 ]] || {
    echo "Run as root: sudo $0 $*" >&2
    exit 1
  }
}

require_shutoff() {
  local state
  state="$(virsh -c qemu:///system domstate windows11 2>/dev/null || true)"
  [[ "${state}" == "shut off" || -z "${state}" ]] || {
    echo "Shut off windows11 first (state: ${state})." >&2
    exit 1
  }
}

cmd_backup() {
  require_root
  require_shutoff
  [[ -f "${DISK}" ]] || { echo "Missing ${DISK}" >&2; exit 1; }
  echo "Backing up to ${BACKUP} ..."
  cp -a -- "${DISK}" "${BACKUP}"
  ls -lh "${DISK}" "${BACKUP}"
}

cmd_check() {
  require_root
  require_shutoff
  qemu-img check -r all "${DISK}"
}

cmd_info() {
  require_root
  qemu-img info "${DISK}"
}

main() {
  case "${1:-}" in
    backup) cmd_backup ;;
    check) cmd_check ;;
    info) cmd_info ;;
    -h|--help|"") usage ;;
    *) echo "Unknown: $1" >&2; usage >&2; exit 2 ;;
  esac
}

main "$@"
