#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Enable Intel IOMMU + bind an AMD GPU to vfio-pci via Limine cmdline.

Usage:
  sudo vfio-limine-enable [--ids GPU_ID,AUDIO_ID] [--entry-regex REGEX] [--config PATH]

Defaults:
  --ids         autodetected from lspci (first AMD VGA/3D + its HDMI/DP Audio)
  --entry-regex linux-cachyos
  --config      autodetect common Limine config paths under /boot

Example:
  sudo vfio-limine-enable
  sudo vfio-limine-enable --ids 1002:744c,1002:ab30
EOF
}

IDS=""
ENTRY_REGEX="linux-cachyos"
CONFIG_PATH=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --ids)
      IDS="${2:-}"; shift 2 ;;
    --entry-regex)
      ENTRY_REGEX="${2:-}"; shift 2 ;;
    --config)
      CONFIG_PATH="${2:-}"; shift 2 ;;
    -h|--help)
      usage; exit 0 ;;
    *)
      echo "Unknown argument: $1" >&2
      usage
      exit 2 ;;
  esac
done

if [[ "${EUID}" -ne 0 ]]; then
  echo "Please run as root (use sudo)." >&2
  exit 1
fi

if [[ -z "${IDS}" ]]; then
  GPU_ID="$(
    lspci -nn |
      awk 'BEGIN{IGNORECASE=1}
           /AMD|Advanced Micro Devices/ && (/VGA compatible controller|3D controller|Display controller/){
             if (match($0, /\[[0-9a-fA-F]{4}:[0-9a-fA-F]{4}\]/)) {
               id=substr($0, RSTART+1, RLENGTH-2);
               print id;
               exit
             }
           }'
  )"

  AUDIO_ID="$(
    lspci -nn |
      awk 'BEGIN{IGNORECASE=1}
           /AMD|Advanced Micro Devices/ && /Audio device/ && /HDMI|DP/{
             if (match($0, /\[[0-9a-fA-F]{4}:[0-9a-fA-F]{4}\]/)) {
               id=substr($0, RSTART+1, RLENGTH-2);
               print id;
               exit
             }
           }'
  )"

  if [[ -z "${GPU_ID}" || -z "${AUDIO_ID}" ]]; then
    echo "Could not autodetect AMD GPU + HDMI/DP Audio IDs from lspci." >&2
    echo "Re-run with: --ids GPU_ID,AUDIO_ID" >&2
    exit 1
  fi

  IDS="${GPU_ID},${AUDIO_ID}"
fi

if [[ -z "${CONFIG_PATH}" ]]; then
  for p in \
    /boot/limine.conf \
    /boot/limine.cfg \
    /boot/EFI/limine/limine.conf \
    /boot/EFI/limine/limine.cfg \
    /boot/EFI/BOOT/limine.conf \
    /boot/EFI/BOOT/limine.cfg
  do
    if [[ -f "$p" ]]; then
      CONFIG_PATH="$p"
      break
    fi
  done
fi

if [[ -z "${CONFIG_PATH}" || ! -f "${CONFIG_PATH}" ]]; then
  echo "Could not find a Limine config under /boot." >&2
  echo "Pass it explicitly with: --config /boot/...." >&2
  exit 1
fi

backup="${CONFIG_PATH}.bak.$(date +%Y%m%d-%H%M%S)"
cp -a -- "${CONFIG_PATH}" "${backup}"

tmp="$(mktemp)"
trap 'rm -f "${tmp}"' EXIT

awk -v entryre="${ENTRY_REGEX}" -v ids="${IDS}" '
  function ensure_token(s, tok) {
    return (index(s, tok) ? s : s " " tok);
  }

  function update_cmdline(line) {
    gsub(/[[:space:]]+$/, "", line);
    line = ensure_token(line, "intel_iommu=on");
    line = ensure_token(line, "iommu=pt");
    if (line ~ /vfio-pci\.ids=/) {
      gsub(/vfio-pci\.ids=[^[:space:]]+/, "vfio-pci.ids=" ids, line);
    } else {
      line = ensure_token(line, "vfio-pci.ids=" ids);
    }
    return line;
  }

  BEGIN { IGNORECASE=1; in_entry=0; pending_insert=0; }

  # New entry label starts with ":"
  /^[[:space:]]*:/ {
    in_entry=0;
    pending_insert=0;
    print;
    next;
  }

  # Identify target entry by its kernel path. CachyOS/Limine configs may use
  # either "kernel_path:" or "path:" depending on the generator version.
  /^[[:space:]]*(kernel_path|path):[[:space:]]*/ {
    if ($0 ~ entryre) {
      in_entry=1;
      pending_insert=1;
    } else {
      in_entry=0;
      pending_insert=0;
    }
    print;
    next;
  }

  # Insert a cmdline right after kernel_path if missing
  pending_insert == 1 && $0 !~ /^[[:space:]]*cmdline:[[:space:]]*/ {
    print "cmdline: " update_cmdline("");
    pending_insert=0;
    print;
    next;
  }

  pending_insert == 1 && $0 ~ /^[[:space:]]*cmdline:[[:space:]]*/ {
    pending_insert=0;
    # fallthrough to cmdline handler below
  }

  # Update cmdline in the target entry
  in_entry == 1 && /^[[:space:]]*cmdline:[[:space:]]*/ {
    sub(/^[[:space:]]*cmdline:[[:space:]]*/, "", $0);
    print "cmdline: " update_cmdline($0);
    next;
  }

  { print; }
' "${CONFIG_PATH}" > "${tmp}"

mv -- "${tmp}" "${CONFIG_PATH}"

echo "Updated: ${CONFIG_PATH}"
echo "Backup:  ${backup}"
echo "Added kernel params: intel_iommu=on iommu=pt vfio-pci.ids=${IDS}"
