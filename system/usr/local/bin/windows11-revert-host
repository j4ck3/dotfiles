#!/usr/bin/env bash
# Reattach GPU to amdgpu and restart Hyprland (after emergency stop / hard reboot).
set -u

if [[ "${EUID}" -ne 0 ]]; then
  exec sudo -E "$0" "$@"
fi

# shellcheck source=/dev/null
source "$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../../../etc/libvirt/windows11" && pwd)/paths.sh"
HANDOFF_LIB="${HANDOFF_LIB:-${GPU_HANDOFF_LIB}}"
HOOK="${HOOK:-${WINDOWS11_HOOKS_DIR}/qemu.d/windows11/release/end/revert.sh}"

if [[ -x "${HOOK}" ]]; then
  echo "Running passthrough revert hook..."
  export GPU_HANDOFF_FORCE=1
  "${HOOK}" windows11 release end -
  exit 0
fi

if [[ -f "${HANDOFF_LIB}" ]]; then
  # shellcheck source=/dev/null
  source "${HANDOFF_LIB}"
  export GPU_HANDOFF_FORCE=1
  hook_log_begin "windows11-revert-host (manual)" "$@"
  hook_log_attach
  set -x
  gpu_handoff_release_end
  exit 0
fi

echo "No hook library found; minimal revert..." >&2
export VIRSH_DEFAULT_CONNECT_URI="${CONNECT_URI:-qemu:///system}"
virsh nodedev-reattach pci_0000_03_00_1 2>/dev/null || true
virsh nodedev-reattach pci_0000_03_00_0 2>/dev/null || true
modprobe amdgpu 2>/dev/null || true
modprobe usbhid 2>/dev/null || true
udevadm trigger --subsystem-match=input 2>/dev/null || true
udevadm trigger --subsystem-match=usb 2>/dev/null || true
udevadm settle 2>/dev/null || true
systemctl restart systemd-vconsole-setup.service 2>/dev/null || true
loginctl flush-devices 2>/dev/null || true
if command -v nmcli >/dev/null; then
  nmcli general reload 2>/dev/null || true
  nmcli networking on 2>/dev/null || true
  for con in br0 eno1 "Wired connection 1"; do
    nmcli -t -f NAME connection show 2>/dev/null | grep -Fxq "${con}" || continue
    nmcli connection up "${con}" 2>/dev/null || true
  done
fi
systemctl start ly@tty1.service ly@tty2.service 2>/dev/null || true
