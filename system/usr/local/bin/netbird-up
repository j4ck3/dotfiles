#!/usr/bin/env bash
# Connect NetBird on LAN hosts: fix DNS for management gRPC, then run netbird up.
set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/dotfiles}"
INSTALL_HOSTS="$DOTFILES/system/install-netbird-hosts.sh"

if ! getent hosts netbird.hjacke.com | awk '{print $1}' | grep -qxF '10.0.0.25'; then
  if [[ -x "$INSTALL_HOSTS" ]]; then
    "$INSTALL_HOSTS"
  else
    echo "netbird.hjacke.com does not resolve to 10.0.0.25 (Cloudflare blocks gRPC)." >&2
    echo "Run: sudo $INSTALL_HOSTS" >&2
    exit 1
  fi
fi

MGMT_URL="${NETBIRD_MGMT_URL:-https://netbird.hjacke.com:443}"
exec netbird up --management-url "$MGMT_URL" "$@"
