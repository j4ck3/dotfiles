#!/usr/bin/env bash
# Build looking-glass-client from source (minimal deps; no system-wide pipewire/nettle upgrades).
set -euo pipefail

LG_REF="${LG_REF:-B7}"
PREFIX="${PREFIX:-/usr/local}"
JOBS="${JOBS:-$(nproc)}"

# Reuse the kvmfr clone when present.
if [[ -d /usr/local/src/looking-glass-kvmfr/.git ]]; then
  BUILD_DIR="${BUILD_DIR:-/usr/local/src/looking-glass-kvmfr}"
else
  BUILD_DIR="${BUILD_DIR:-/usr/local/src/looking-glass-client}"
fi

if [[ "${EUID}" -ne 0 ]]; then
  echo "Run as root: sudo $0" >&2
  exit 1
fi

# Only install packages that are not already present (never bulk-upgrade pipewire/nettle).
WANT_PKGS=(
  cmake gcc pkgconf git
  fontconfig spice-protocol
  libx11 libxi libxinerama libxss libxcursor libxpresent
  libxkbcommon wayland wayland-protocols libdecor
  mesa libglvnd gmp
)

MISSING=()
for pkg in "${WANT_PKGS[@]}"; do
  pacman -Q "${pkg}" &>/dev/null || MISSING+=("${pkg}")
done

if ((${#MISSING[@]} > 0)); then
  echo "Installing missing build packages: ${MISSING[*]}"
  pacman -S --needed --noconfirm "${MISSING[@]}"
else
  echo "All build packages already installed."
fi

for pkg in gmp nettle; do
  if ! pacman -Q "${pkg}" &>/dev/null; then
    echo "WARNING: ${pkg} not installed — cmake may fail; install manually if needed." >&2
  fi
done

install -d -m 0755 "${BUILD_DIR}"
if [[ ! -d "${BUILD_DIR}/.git" ]]; then
  git clone --recursive --depth 1 --branch "${LG_REF}" \
    https://github.com/gnif/LookingGlass.git "${BUILD_DIR}"
else
  git -C "${BUILD_DIR}" fetch --depth 1 origin "${LG_REF}" 2>/dev/null || true
  git -C "${BUILD_DIR}" checkout -f "${LG_REF}" 2>/dev/null || true
fi
git -C "${BUILD_DIR}" submodule update --init --recursive

CLIENT_BUILD="${BUILD_DIR}/client/build"
rm -rf "${CLIENT_BUILD}"
install -d "${CLIENT_BUILD}"

if ! pkg-config --exists libpipewire-0.3 2>/dev/null && ! pacman -Q pipewire &>/dev/null; then
  echo "Install pipewire for the client build: sudo pacman -S pipewire" >&2
  exit 1
fi

# PipeWire generates dynamic/audiodev.h (VM audio still uses GPU HDMI passthrough).
# GCC 15 treats nanosvg -Wmaybe-uninitialized as error; relax for vendored headers.
CMAKE_FLAGS=(
  -DCMAKE_BUILD_TYPE=Release
  -DCMAKE_INSTALL_PREFIX="${PREFIX}"
  -DENABLE_BACKTRACE=0
  -DENABLE_LIBDECOR=ON
  -DENABLE_PIPEWIRE=yes
  -DENABLE_PULSEAUDIO=no
  -DCMAKE_C_FLAGS="-Wno-error=maybe-uninitialized -Wno-maybe-uninitialized"
  -DCMAKE_CXX_FLAGS="-Wno-error=maybe-uninitialized -Wno-maybe-uninitialized"
)

cmake -S "${BUILD_DIR}/client" -B "${CLIENT_BUILD}" "${CMAKE_FLAGS[@]}"

cmake --build "${CLIENT_BUILD}" -j "${JOBS}"
cmake --install "${CLIENT_BUILD}"

if command -v looking-glass-client >/dev/null; then
  echo "OK: $(command -v looking-glass-client)"
else
  echo "OK: ${PREFIX}/bin/looking-glass-client"
fi
