#!/usr/bin/env bash
# Safe passthrough start — use this instead of bare "virsh start windows11".
set -euo pipefail

export LC_ALL=C
export LANG=C

CONNECT_URI="${CONNECT_URI:-qemu:///system}"
DOMAIN="${DOMAIN:-windows11}"
assume_yes=0

host_ip() {
  ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1
}

usage() {
  cat <<EOF
Usage: ${0##*/} [--yes]

Starts ${DOMAIN} in GPU passthrough mode.

IMPORTANT — single monitor on the AMD GPU:
  When the VM runs, Linux has NO picture on that screen. Ctrl+Alt+F3 will NOT
  help you see a rescue TTY (same physical outputs as the VM).

  Before starting, use ONE of:
    • SSH from phone/laptop:  ssh YOU@HOST 'windows11-force-stop'
    • Second monitor on Intel motherboard HDMI (host rescue screen)

Options:
  --yes, -y             Start without confirmation prompt

If Windows appears: shut down from Start menu (do not hard power-off the PC).
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --yes|-y) assume_yes=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ ! -e /etc/libvirt/hooks/windows11-gpu-passthrough.enabled ]]; then
  echo "Passthrough hook is disabled. Run: sudo windows11-mode passthrough" >&2
  exit 1
fi

state="$(virsh -c "${CONNECT_URI}" domstate "${DOMAIN}" 2>/dev/null || true)"
if [[ "${state}" == "running" ]]; then
  echo "${DOMAIN} is already running."
  exit 0
fi

if ! [[ -f /var/lib/libvirt/vbios/rx7900xtx.rom ]]; then
  echo "Missing VBIOS. Run: sudo windows11-dump-vbios" >&2
  exit 1
fi
if ! virsh -c "${CONNECT_URI}" dumpxml "${DOMAIN}" | grep -q 'rx7900xtx\.rom'; then
  echo "GPU VBIOS ROM not in domain XML. Run: sudo windows11-mode passthrough" >&2
  exit 1
fi

ip_addr="$(host_ip || true)"
user="$(id -un)"

cat <<EOF

=== Passthrough start checklist ===
  Monitor:     cable on RX 7900 only (Intel/iGPU will stay black — not Windows)
  BIOS:        IOMMU/VT-d + Above 4G on
  Recovery:    ssh ${user}@${ip_addr:-YOUR_HOST_IP} 'windows11-force-stop'
                 (if display broken after stop) ssh ${user}@${ip_addr:-YOUR_HOST_IP} 'sudo windows11-revert-host'
EOF

if systemctl is-active --quiet sshd 2>/dev/null; then
  echo "  SSH:         active"
else
  echo "  SSH:         NOT RUNNING — enable sshd before passthrough!" >&2
fi

if [[ "${assume_yes}" -eq 0 ]]; then
  echo ""
  if ! [[ -t 0 ]]; then
    echo "Not a TTY — use: ${0##*/} --yes" >&2
    exit 1
  fi
  read -r -p "Start ${DOMAIN} now? [y/N] " ans
  if [[ "${ans,,}" != "y" && "${ans,,}" != "yes" ]]; then
    echo "Cancelled (no changes). Use --yes to skip this prompt."
    exit 0
  fi
fi

echo ""
echo "Starting ${DOMAIN}..."
virsh -c "${CONNECT_URI}" start "${DOMAIN}"
echo "Started. Windows appears ONLY on the RX 7900 port (not motherboard HDMI)."
echo "Kernel text on Intel/iGPU during revert is normal (amdgpu overdrive notice)."
echo "Black on AMD? Run: windows11-passthrough-doctor"
echo "If still black after 2 min, recover via SSH (see checklist above)."
