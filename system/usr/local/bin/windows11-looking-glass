#!/usr/bin/env bash
# Run Looking Glass client (host view of the Windows VM framebuffer).
set -euo pipefail

if [[ -c /dev/kvmfr0 ]]; then
  CFG="${LG_CONFIG:-/etc/libvirt/windows11/looking-glass.ini}"
elif [[ -f /dev/shm/looking-glass ]]; then
  CFG="${LG_CONFIG:-/etc/libvirt/windows11/looking-glass-shm.ini}"
else
  echo "No Looking Glass memory device. Start the VM or run:" >&2
  echo "  sudo windows11-setup-kvmfr   # recommended" >&2
  echo "  sudo systemd-tmpfiles --create /etc/tmpfiles.d/10-looking-glass.conf" >&2
  exit 1
fi

if ! command -v looking-glass-client >/dev/null; then
  echo "Install client (try obs-studio mirror fix first):" >&2
  echo "  sudo pacman -S obs-studio" >&2
  echo "  paru -S looking-glass --needed" >&2
  echo "Or build from: https://github.com/gnif/LookingGlass" >&2
  exit 1
fi

if ! virsh -c qemu:///system domstate windows11 2>/dev/null | grep -qx running; then
  echo "windows11 is not running. Start passthrough first: windows11-start" >&2
  exit 1
fi

exec looking-glass-client -F "${CFG}" "$@"
