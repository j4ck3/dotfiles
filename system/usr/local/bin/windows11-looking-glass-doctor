#!/usr/bin/env bash
# Verify Looking Glass host + libvirt setup; fix XML; optional start VM + client.
set -euo pipefail

export LC_ALL=C LANG=C
CONNECT_URI="${CONNECT_URI:-qemu:///system}"
DOMAIN="${DOMAIN:-windows11}"
FIX="${FIX:-1}"
START_VM="${START_VM:-0}"
START_CLIENT="${START_CLIENT:-0}"

ok() { printf '  OK   %s\n' "$*"; }
warn() { printf '  WARN %s\n' "$*" >&2; }
fail() { printf '  FAIL %s\n' "$*" >&2; FAILURES=$((FAILURES + 1)); }

FAILURES=0

echo "=== Looking Glass doctor (Context7 / B7 checklist) ==="
echo ""

echo "1. kvmfr module"
if [[ -c /dev/kvmfr0 ]]; then
  ok "/dev/kvmfr0 $(ls -l /dev/kvmfr0 | awk '{print $1, $3, $4}')"
  dmesg 2>/dev/null | grep -q kvmfr && ok "dmesg shows kvmfr loaded" || warn "kvmfr device exists but no dmesg line"
else
  fail "/dev/kvmfr0 missing — run: sudo windows11-setup-kvmfr"
fi

echo ""
echo "2. Client binary"
if command -v looking-glass-client >/dev/null; then
  ok "$(command -v looking-glass-client)"
else
  fail "looking-glass-client not installed — run: sudo windows11-build-looking-glass-client"
fi

echo ""
echo "3. User permissions (kvm group for kvmfr)"
if id -nG "${SUDO_USER:-$USER}" | grep -qw kvm; then
  ok "user in group kvm"
else
  fail "add kvm: sudo usermod -aG kvm ${SUDO_USER:-$USER}  (re-login)"
fi
if [[ -c /dev/kvmfr0 ]] && [[ -r /dev/kvmfr0 ]]; then
  ok "can read /dev/kvmfr0"
elif [[ -c /dev/kvmfr0 ]]; then
  warn "cannot read /dev/kvmfr0 in this shell — run: newgrp kvm"
fi

echo ""
echo "4. libvirt domain IVSHMEM (must use kvmfr when /dev/kvmfr0 exists)"
if ! virsh -c "${CONNECT_URI}" dominfo "${DOMAIN}" &>/dev/null; then
  fail "domain ${DOMAIN} not found"
else
  XML="$(virsh -c "${CONNECT_URI}" dumpxml "${DOMAIN}")"
  if [[ -c /dev/kvmfr0 ]]; then
    if grep -q "mem-path.*kvmfr0" <<<"${XML}"; then
      ok "domain XML uses kvmfr (/dev/kvmfr0)"
    elif grep -q "<shmem name='looking-glass'>" <<<"${XML}"; then
      fail "domain uses <shmem> but kvmfr is loaded — run: sudo windows11-mode passthrough"
      if [[ "${FIX}" -eq 1 && "${EUID}" -eq 0 ]]; then
        echo "     Applying fix ..."
        windows11-mode passthrough
        XML="$(virsh -c "${CONNECT_URI}" dumpxml "${DOMAIN}")"
        grep -q "kvmfr0" <<<"${XML}" && ok "fixed: now uses kvmfr0"
      fi
    else
      fail "no Looking Glass IVSHMEM in domain XML"
    fi
  else
    grep -q "looking-glass" <<<"${XML}" && ok "IVSHMEM present (shm fallback)" \
      || fail "no IVSHMEM — sudo windows11-mode passthrough"
  fi
  grep -q "type='evdev'" <<<"${XML}" && ok "evdev input configured" \
    || warn "no evdev inputs"
  grep -q "<sound " <<<"${XML}" && warn "emulated ich9 sound still present" \
    || ok "no virtual ich9 sound"
  grep -q "rx7900xtx.rom" <<<"${XML}" && ok "GPU VBIOS ROM in XML" \
    || warn "GPU VBIOS ROM missing"
fi

echo ""
echo "5. libvirt cgroup (kvmfr access for QEMU)"
if grep -q '^#*cgroup_device_acl' /etc/libvirt/qemu.conf 2>/dev/null; then
  if grep -A20 'cgroup_device_acl' /etc/libvirt/qemu.conf | grep -q kvmfr0; then
    ok "cgroup_device_acl includes /dev/kvmfr0"
  else
    warn "uncomment cgroup_device_acl in /etc/libvirt/qemu.conf and add \"/dev/kvmfr0\""
  fi
fi

echo ""
echo "6. Guest (manual)"
echo "  • Install Looking Glass Host (B7) inside Windows"
echo "  • AMD driver + Fast Startup off"
echo "  • Host and guest LG versions must match"

STATE="$(virsh -c "${CONNECT_URI}" domstate "${DOMAIN}" 2>/dev/null || echo missing)"
echo ""
echo "7. VM state: ${STATE}"

if [[ "${START_VM}" -eq 1 && "${STATE}" == "shut off" ]]; then
  echo "Starting ${DOMAIN} ..."
  if [[ -x /usr/local/bin/windows11-start ]]; then
    windows11-start --yes --no-watchdog 2>/dev/null || virsh -c "${CONNECT_URI}" start "${DOMAIN}"
  else
    virsh -c "${CONNECT_URI}" start "${DOMAIN}"
  fi
  sleep 2
  STATE="$(virsh -c "${CONNECT_URI}" domstate "${DOMAIN}")"
  echo "  State now: ${STATE}"
fi

echo ""
echo "8. Logs (last lines)"
for log in /var/log/windows11-passthrough-hook.log "/var/log/libvirt/qemu/${DOMAIN}.log"; do
  if [[ -r "${log}" ]]; then
    echo "--- ${log} ---"
    tail -15 "${log}"
  elif [[ -f "${log}" ]]; then
    echo "--- ${log} (unreadable, try sudo) ---"
  fi
done

if [[ "${START_CLIENT}" -eq 1 && "${STATE}" == "running" ]] && command -v looking-glass-client >/dev/null; then
  echo ""
  echo "Starting looking-glass-client ..."
  exec windows11-looking-glass
fi

echo ""
if [[ "${FAILURES}" -eq 0 ]]; then
  echo "Result: READY (guest Host app must still be installed in Windows)"
  exit 0
fi
echo "Result: ${FAILURES} issue(s) — fix above, then: sudo $0"
exit 1
