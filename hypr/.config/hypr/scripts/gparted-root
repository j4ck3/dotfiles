#!/usr/bin/env bash
# Run GParted as root without pkexec (works when no polkit agent is available).
# Uses your current Wayland / XWayland session from the terminal you start it in.
exec sudo -E env DISPLAY="${DISPLAY:-}" WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
	XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
	DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}" \
	HOME="${HOME}" \
	/usr/lib/gparted/gpartedbin "$@"
