#!/usr/bin/env bash
# Toggle: put ALL tiled windows on current workspace into 16:9 stacking mode, or revert.
# Skips already-floating windows (dialogs/popups) so they render on top correctly.
# Tracks which addresses were floated so revert only tiles those back.

MODE_FLAG="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/.16-9-ws-mode"

WIN_JSON=$(hyprctl activewindow -j 2>/dev/null) || exit 0
[[ -z "$WIN_JSON" ]] && exit 0

WORKSPACE_ID=$(jq -r '.workspace.id' <<< "$WIN_JSON")
MON_ID=$(jq -r '.monitor' <<< "$WIN_JSON")
MON_JSON=$(hyprctl monitors -j 2>/dev/null | jq -c --argjson id "$MON_ID" '.[] | select(.id == $id)')
[[ -z "$MON_JSON" ]] && exit 0

MON_X=$(jq -r '.x' <<< "$MON_JSON")
MON_Y=$(jq -r '.y' <<< "$MON_JSON")
MON_W=$(jq -r '.width' <<< "$MON_JSON")
MON_H=$(jq -r '.height' <<< "$MON_JSON")
TOP=$(jq -r '.reserved[1]' <<< "$MON_JSON")
BOTTOM=$(jq -r '.reserved[3]' <<< "$MON_JSON")

GAPS_STR=$(hyprctl -j getoption general:gaps_out 2>/dev/null | jq -r '.custom')
GAPS_L=0; GAPS_T=0; GAPS_R=0; GAPS_B=0
[[ -n "$GAPS_STR" ]] && read -r GAPS_L GAPS_T GAPS_R GAPS_B <<< "$GAPS_STR"

WORK_LEFT=$((MON_X + GAPS_L))
WORK_TOP=$((MON_Y + TOP + GAPS_T))
WORK_W=$((MON_W - GAPS_L - GAPS_R))
WORK_H=$((MON_H - TOP - BOTTOM - GAPS_T - GAPS_B))

USE_H=$WORK_H
USE_W=$((USE_H * 16 * 108 / 9 / 100))
WIN_LEFT=$((WORK_LEFT + (WORK_W - USE_W) / 2))
WIN_TOP=$WORK_TOP

# Revert: only tile windows we previously floated (leaves dialogs/popups alone)
if [[ -f "$MODE_FLAG" ]] && [[ "$(head -1 "$MODE_FLAG" 2>/dev/null)" == "$WORKSPACE_ID" ]]; then
	hyprctl keyword animations:enabled false
	while IFS= read -r addr; do
		[[ -n "$addr" ]] && hyprctl dispatch settiled "address:$addr"
	done < <(tail -n +2 "$MODE_FLAG")
	hyprctl keyword animations:enabled true
	rm -f "$MODE_FLAG"
	exit 0
fi

# Enter stacking: only float tiled windows (skip dialogs/popups that are already floating)
ALL_CLIENTS=$(hyprctl clients -j 2>/dev/null)
ADDRESSES=()
while IFS= read -r addr; do
	[[ -n "$addr" ]] && ADDRESSES+=( "$addr" )
done < <(echo "$ALL_CLIENTS" | jq -r --argjson ws "$WORKSPACE_ID" \
	'.[] | select(.workspace.id == $ws and .mapped == true and .floating == false) | .address')

[[ ${#ADDRESSES[@]} -eq 0 ]] && exit 0

hyprctl keyword animations:enabled false
for addr in "${ADDRESSES[@]}"; do
	hyprctl --batch "dispatch setfloating address:$addr ; dispatch resizewindowpixel exact ${USE_W} ${USE_H},address:${addr} ; dispatch movewindowpixel exact ${WIN_LEFT} ${WIN_TOP},address:${addr}"
done
hyprctl keyword animations:enabled true

printf '%s\n' "$WORKSPACE_ID" "${ADDRESSES[@]}" > "$MODE_FLAG"
