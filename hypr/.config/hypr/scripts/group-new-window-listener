#!/usr/bin/env bash
# First tiled window on a workspace → 16:9 group. Further windows join the stack.
# Floating popups are ignored. Workspace 2 excluded unless SUPER+T enabled 16:9 there.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/16-9-lib.sh"

RUNTIME="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
SOCKET=""
for _ in $(seq 15); do
	for s in "$RUNTIME"/hypr/*/.socket2.sock; do
		[[ -S "$s" ]] && SOCKET="$s" && break 2
	done
	sleep 0.2
done
[[ -z "$SOCKET" ]] && exit 0

export XDG_RUNTIME_DIR="$RUNTIME"
export HYPRLAND_INSTANCE_SIGNATURE=$(basename "$(dirname "$SOCKET")")

handle_openwindow() {
	local addr="$1"
	[[ "$addr" != 0x* ]] && addr="0x$addr"

	local win_json
	for _ in $(seq 30); do
		win_json=$(hyprctl clients -j 2>/dev/null | jq -c --arg a "$addr" '.[] | select(.address == $a)')
		[[ -n "$win_json" ]] && break
		sleep 0.02
	done
	[[ -z "$win_json" ]] && return

	[[ "$(jq -r '.floating' <<<"$win_json")" == "true" ]] && return

	local ws_id tiled_count mode
	ws_id=$(jq -r '.workspace.id' <<<"$win_json")
	tiled_count=$(hyprctl clients -j 2>/dev/null \
		| jq -r --argjson ws "$ws_id" '[.[] | select(.workspace.id == $ws and .mapped == true and .floating == false)] | length')
	mode=$(head -1 "$MODE_FLAG" 2>/dev/null)

	if [[ "$ws_id" == "2" ]]; then
		[[ "$mode" == "all" || "$mode" == "2" ]] || return
	elif [[ "$tiled_count" -le 1 ]]; then
		sixteen_nine_enable_workspace "$ws_id"
	else
		[[ "$mode" == "all" || "$mode" == "$ws_id" ]] || return
		local cur_ws
		cur_ws=$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id // empty')
		[[ "$cur_ws" == "$ws_id" ]] || return
	fi

	sixteen_nine_apply_to_address "$addr"
}

while IFS= read -r addr; do
	[[ -z "$addr" ]] && continue
	handle_openwindow "$addr" &
done < <(python3 - "$SOCKET" <<'PY'
import sys, socket, time

sock_path = sys.argv[1]
s = None
for _ in range(30):
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.connect(sock_path)
        break
    except (ConnectionRefusedError, FileNotFoundError, OSError):
        time.sleep(0.2)
else:
    sys.exit(0)

buf = b""
while True:
    data = s.recv(4096)
    if not data:
        break
    buf += data
    while b"\n" in buf:
        line, buf = buf.split(b"\n", 1)
        line = line.decode("utf-8", errors="replace").strip()
        if not line.startswith("openwindow>>"):
            continue
        payload = line[len("openwindow>>") :]
        idx = payload.find(",")
        addr = (payload[:idx] if idx >= 0 else payload).strip()
        if addr:
            print(addr, flush=True)
PY
)
