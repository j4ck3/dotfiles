#!/usr/bin/env bash
# Open a top-level project from /work in nnn, then jump into a two-window tmux session.
# Usage: open-project-tmux

set -euo pipefail

pick_projects_dir() {
    if [ -n "${PROJECTS_DIR:-}" ] && [ -d "${PROJECTS_DIR}" ]; then
        printf '%s\n' "${PROJECTS_DIR}"
        return
    fi

    if [ -d "/work" ]; then
        printf '%s\n' "/work"
        return
    fi

    if [ -d "$HOME/Work" ]; then
        printf '%s\n' "$HOME/Work"
        return
    fi

    if [ -d "$HOME/work" ]; then
        printf '%s\n' "$HOME/work"
        return
    fi

    printf '%s\n' "$HOME"
}

show_error() {
    printf '%s\n' "$1" >&2
    printf 'Press Enter to close...'
    read -r _
}

require_cmd() {
    if command -v "$1" >/dev/null 2>&1; then
        return
    fi

    show_error "Missing required command: $1"
    exit 1
}

sanitize_session_name() {
    local path="$1"
    local name

    name="$(printf '%s\n' "$path" | sed "s|^$HOME|home|; s|[^[:alnum:]_.-]|-|g; s|-\\{2,\\}|-|g; s|^-||; s|-$||")"

    if [ -z "$name" ]; then
        name="project"
    fi

    if [ "${#name}" -gt 48 ]; then
        name="${name: -48}"
    fi

    printf '%s\n' "$name"
}

ensure_tmux_window() {
    local session_name="$1"
    local window_name="$2"
    local project_dir="$3"
    local command="${4:-}"

    if tmux list-windows -t "$session_name" -F '#{window_name}' 2>/dev/null | grep -Fxq "$window_name"; then
        return
    fi

    if [ -n "$command" ]; then
        tmux new-window -t "$session_name" -n "$window_name" -c "$project_dir" "$command"
        return
    fi

    tmux new-window -t "$session_name" -n "$window_name" -c "$project_dir"
}

open_tmux_session() {
    local project_dir="$1"
    local session_name

    session_name="$(sanitize_session_name "$project_dir")"

    if tmux has-session -t "$session_name" 2>/dev/null; then
        ensure_tmux_window "$session_name" "nvim" "$project_dir" "nvim"
        ensure_tmux_window "$session_name" "shell" "$project_dir"
        tmux select-window -t "$session_name:nvim"
        exec tmux attach-session -t "$session_name"
    fi

    tmux new-session -d -s "$session_name" -n "nvim" -c "$project_dir" "nvim"
    tmux new-window -t "$session_name" -n "shell" -c "$project_dir"
    tmux select-window -t "$session_name:nvim"
    exec tmux attach-session -t "$session_name"
}

run_picker() {
    local projects_dir="$1"
    local picker_dir pick_file selected_entry selected_dir
    local -a project_dirs=()

    require_cmd nnn
    require_cmd tmux
    require_cmd nvim

    mapfile -d '' project_dirs < <(
        find "$projects_dir" -mindepth 1 -maxdepth 1 -type d ! -name '.*' -print0 | sort -z
    )

    if [ "${#project_dirs[@]}" -eq 0 ]; then
        show_error "No project directories found in $projects_dir"
        exit 0
    fi

    picker_dir="$(mktemp -d)"
    pick_file="$(mktemp)"
    trap 'rm -rf "$picker_dir" "$pick_file"' EXIT

    local project_dir project_name
    for project_dir in "${project_dirs[@]}"; do
        project_name="${project_dir##*/}"
        printf '%s\n' "$project_dir" > "$picker_dir/$project_name"
    done

    nnn -p "$pick_file" "$picker_dir"

    if ! IFS= read -r selected_entry < "$pick_file"; then
        exit 0
    fi

    if [ ! -f "$selected_entry" ]; then
        exit 0
    fi

    selected_dir="$(<"$selected_entry")"

    if [ ! -d "$selected_dir" ]; then
        show_error "Selected path is not a directory: $selected_dir"
        exit 1
    fi

    open_tmux_session "$selected_dir"
}

PROJECTS_ROOT="$(pick_projects_dir)"

if [ "${1:-}" != "--inside-terminal" ]; then
    exec uwsm-app -- xdg-terminal-exec -e "$0" --inside-terminal "$PROJECTS_ROOT"
fi

run_picker "${2:-$PROJECTS_ROOT}"
