#!/usr/bin/env bash
# One-shot display + browser pipeline checks (Hyprland + Helium/Chromium).
set -euo pipefail

echo "== Hyprland monitors (refresh / vrr / scanout) =="
hyprctl monitors -j 2>/dev/null | jq -r '.[] | "\(.name)  \(.width)x\(.height)  \(.refreshRate) Hz  vrr=\(.vrr)  directScanoutTo=\(.directScanoutTo)"' || echo "(hyprctl failed)"

echo
echo "== Hyprland render (flicker-related) =="
hyprctl getoption render:send_content_type 2>/dev/null || true
hyprctl getoption render:direct_scanout 2>/dev/null || true
hyprctl getoption misc:vrr 2>/dev/null || true
grep -E '^env = (AQ_NO_ATOMIC|AQ_DRM|__GL_VRR)' "${XDG_CONFIG_HOME:-$HOME/.config}/hypr/envs.conf" 2>/dev/null || true
echo "AQ_NO_ATOMIC in Hyprland process (needs full session restart after env change):"
tr '\0' '\n' <"/proc/$(pgrep -x Hyprland 2>/dev/null || echo 0)/environ" 2>/dev/null | rg '^AQ_NO_ATOMIC=' || echo "  (not visible — log out/in once if flicker remains)"

echo
echo "== AMDGPU DP mode (modetest) =="
if command -v modetest >/dev/null; then
	modetest -M amdgpu -c 2>/dev/null | grep -F -A18 'DP-2' | head -22
else
	echo "(install libdrm modetest for this block)"
fi

echo
echo "== Helium main process vs flags file =="
flags_file="${XDG_CONFIG_HOME:-$HOME/.config}/helium-browser-flags.conf"
main_pid="$(pgrep -af '^/opt/helium-browser-bin/helium --homepage' | awk '{print $1; exit}' || true)"
if [[ -z "${main_pid:-}" ]]; then
	echo "No main Helium process found (pattern: helium --homepage...)."
else
	echo "Main PID: $main_pid"
	tr '\0' ' ' <"/proc/$main_pid/cmdline" | fold -s -w 100
	echo
	if [[ -r "$flags_file" ]]; then
		echo "Checking tokens from: $flags_file"
		cmd_flat="$(tr '\0' ' ' <"/proc/$main_pid/cmdline")"
		while IFS= read -r line; do
			[[ "$line" =~ ^[[:space:]]*(#|$) ]] && continue
			[[ "$line" != --* ]] && continue
			token="${line%%[[:space:]]*}"
			case "$cmd_flat" in
				*"${token}"*) echo "  OK   $token" ;;
				*) echo "  MISS $token  (run: ~/.config/hypr/scripts/helium-restart)" ;;
			esac
		done <"$flags_file"
		if [[ "$cmd_flat" != *WaylandWpColorManagerV1* && "$cmd_flat" == *enable-features=* ]]; then
			echo "  WARN Helium missing WaylandWpColorManagerV1 disable (stale session or flags not loaded)"
		fi
	else
		echo "Flags file not readable: $flags_file"
	fi
	gpu_pid="$(pgrep -af 'helium.*--type=gpu-process' | awk '{print $1; exit}' || true)"
	if [[ -n "${gpu_pid:-}" ]]; then
		echo
		echo "GPU process render node:"
		tr '\0' ' ' <"/proc/$gpu_pid/cmdline" | grep -oE 'render-node-override=[^ ]+' || echo "  (no override in cmdline)"
		ls -l "/proc/$gpu_pid/fd" 2>/dev/null | grep -E 'renderD|by-path' || true
	fi
fi

echo
echo "== Hyprland compositor FPS (debug overlay) =="
echo "Run:  hyprctl keyword debug:overlay true"
echo "Then: hyprctl keyword debug:overlay false"
