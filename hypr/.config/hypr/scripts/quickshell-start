#!/usr/bin/env bash
# Start Quickshell desktop shell (bar + popups).
set -euo pipefail

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell"

QS_BIN=""
if command -v qs >/dev/null 2>&1; then
  QS_BIN=$(command -v qs)
elif command -v quickshell >/dev/null 2>&1; then
  QS_BIN=$(command -v quickshell)
fi

if [[ -z "$QS_BIN" ]]; then
  echo "quickshell not found. Install: sudo pacman -S --needed quickshell" >&2
  exit 1
fi

# Free org.freedesktop.Notifications for Quickshell's NotificationServer.
pkill -x dunst 2>/dev/null || true

# Prefer qs kill when available (handles socket cleanup).
if command -v qs >/dev/null 2>&1; then
  qs kill 2>/dev/null || true
else
  pkill -x quickshell 2>/dev/null || true
fi

exec "$QS_BIN" -p "$CONFIG" "$@"
