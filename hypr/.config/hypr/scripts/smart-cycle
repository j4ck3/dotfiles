#!/usr/bin/env bash
# Smart ALT+TAB: cycle group tabs when in a group, otherwise cycle windows normally.
# Usage: smart-cycle [prev]

# Hyprland may list only the focused window in .grouped (length 1). changegroupactive
# does nothing useful then — only treat as a real tab group when 2+ members.
GROUPED_LEN=$(hyprctl activewindow -j 2>/dev/null | jq -r '(.grouped // []) | length')

if [[ "$GROUPED_LEN" -gt 1 ]]; then
    if [[ "$1" == "prev" ]]; then
        hyprctl dispatch changegroupactive b
    else
        hyprctl dispatch changegroupactive f
    fi
else
    if [[ "$1" == "prev" ]]; then
        hyprctl --batch "dispatch cyclenext prev ; dispatch alterzorder top"
    else
        hyprctl --batch "dispatch cyclenext ; dispatch alterzorder top"
    fi
fi
