#!/usr/bin/env bash
# Keep group-new-window-listener alive (exec-once only runs once per Hyprland session).
set -u

LISTENER="${HOME}/.config/hypr/scripts/group-new-window-listener"
LOG="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/.16-9-listener.log"
MAX_LOG_BYTES=$((512 * 1024))

wait_for_socket() {
	local runtime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
	local s
	for _ in $(seq 30); do
		for s in "$runtime"/hypr/*/.socket2.sock; do
			[[ -S "$s" ]] && return 0
		done
		sleep 0.5
	done
	return 1
}

rotate_log() {
	[[ -f "$LOG" ]] || return 0
	local size
	size=$(stat -c%s "$LOG" 2>/dev/null || echo 0)
	(( size > MAX_LOG_BYTES )) && : >"$LOG"
}

while true; do
	rotate_log
	wait_for_socket || {
		sleep 2
		continue
	}
	"$LISTENER" >>"$LOG" 2>&1 || true
	sleep 2
done
