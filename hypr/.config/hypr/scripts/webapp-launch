#!/bin/bash
# Switch to workspace and launch app if not already there
# Usage: webapp-launch <workspace> <app_class> <launch_command...>

WORKSPACE="$1"
APP_CLASS="$2"
shift 2

hyprctl dispatch workspace "$WORKSPACE"

WINDOWS=$(hyprctl clients -j | jq "[.[] | select(.workspace.name == \"$WORKSPACE\" and .class == \"$APP_CLASS\")] | length")

if [ "$WINDOWS" -eq 0 ]; then
    hyprctl keyword windowrule "workspace $WORKSPACE silent, match:class $APP_CLASS"
    "$@" &
    (sleep 5 && hyprctl keyword windowrule "unset workspace, match:class $APP_CLASS") &
fi
