#!/bin/bash
# Switch to workspace 2 (current monitor). Focus t3code if already open; never launch it.

WORKSPACE="${1:-2}"

get_client() {
    hyprctl clients -j | jq -r '[.[] | select(
        (.class == "t3code" or .class == "T3code")
        or (((.class // "") | ascii_downcase) | contains("t3code"))
    )][0].address // empty'
}

CLIENT="$(get_client)"

if [ -n "$CLIENT" ]; then
    hyprctl dispatch movetoworkspacesilent "$WORKSPACE,address:$CLIENT"
    hyprctl dispatch focusworkspaceoncurrentmonitor "$WORKSPACE"
    hyprctl dispatch focuswindow "address:$CLIENT"
    exit 0
fi

hyprctl dispatch focusworkspaceoncurrentmonitor "$WORKSPACE"
