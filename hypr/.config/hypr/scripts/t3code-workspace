#!/bin/bash
# Put t3code on the requested workspace and focus it, launching if needed.

WORKSPACE="${1:-2}"

get_client() {
    hyprctl clients -j | jq -r '[.[] | select(
        (.class == "t3code" or .class == "T3code")
        or (((.class // "") | ascii_downcase) | contains("t3code"))
    )][0].address // empty'
}

move_and_focus() {
    local client="$1"

    hyprctl dispatch movetoworkspacesilent "$WORKSPACE,address:$client"
    hyprctl dispatch workspace "$WORKSPACE"
    hyprctl dispatch focuswindow "address:$client"
}

CLIENT="$(get_client)"

if [ -n "$CLIENT" ]; then
    move_and_focus "$CLIENT"
    exit 0
fi

hyprctl dispatch workspace "$WORKSPACE"
uwsm-app -- t3code &

for _ in $(seq 1 40); do
    sleep 0.25
    CLIENT="$(get_client)"
    if [ -n "$CLIENT" ]; then
        move_and_focus "$CLIENT"
        exit 0
    fi
done

exit 0
