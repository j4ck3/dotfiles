#!/usr/bin/env bash
# GNOME Keyring secrets agent (libsecret). Required for Cursor/VS Code cloud sync on Hyprland.
set -eu
if ! command -v gnome-keyring-daemon >/dev/null 2>&1; then
	echo "start-keyring: install gnome-keyring (pacman -S gnome-keyring)" >&2
	exit 0
fi
exec gnome-keyring-daemon --start --components=secrets,ssh,pkcs11
