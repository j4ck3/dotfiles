Host *
    AddKeysToAgent yes
    IdentitiesOnly yes

Host gitlab
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/gitlab_privatekey

Host github
    HostName github.com
    User git
    IdentityFile ~/.ssh/gitlab_github_privatekey

Host web
    HostName CHANGE_ME
    User CHANGE_ME
    IdentityFile ~/.ssh/web_privatekey

Host tower
    HostName 10.0.0.24
    User root
    IdentityFile ~/.ssh/tower_privatekey
