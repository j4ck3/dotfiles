# macOS Big Sur-style banners: frosted dark card, squircle icon, separate cards.
# Blur comes from Hyprland layerrule on namespace "dunst" (hypr/looknfeel.conf).

[global]
    monitor = 0
    follow = none

    # Banner width ~ macOS; height grows with content.
    width = 360
    height = (0, 110)
    origin = top-right
    offset = (14, 40)
    scale = 0

    notification_limit = 0
    indicate_hidden = no
    sort = update

    # Roomy macOS-like padding.
    padding = 15
    horizontal_padding = 16
    text_icon_padding = 14
    separator_height = 0
    gap_size = 10

    # No hard frame; rely on translucent fill + blur.
    frame_width = 0
    frame_color = "#00000000"

    font = Inter 11
    line_height = 3
    markup = full
    # Bold title, muted body line (macOS Notification Center look).
    format = "<b>%s</b>\n<span foreground='#b0b0b8'>%b</span>"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = end
    ignore_newline = no
    stack_duplicates = false
    hide_duplicate_count = true
    show_indicators = no

    # Big squircle-ish rounding.
    corner_radius = 18
    icon_corner_radius = 11
    icon_corners = all

    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 0
    progress_bar_corner_radius = 2
    progress_bar_min_width = 90

    enable_recursive_icon_lookup = true
    icon_theme = Adwaita
    icon_position = left
    min_icon_size = 40
    max_icon_size = 44

    history_length = 30
    sticky_history = yes

    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

    browser = /usr/bin/xdg-open
    layer = overlay

[experimental]
    pause_on_mouse_over = true

# macOS dark banners are a translucent near-black gray (#RRGGBBAA).
[urgency_low]
    background = "#1c1c1e99"
    foreground = "#f5f5f7"
    timeout = 5

[urgency_normal]
    background = "#1c1c1eb3"
    foreground = "#f5f5f7"
    timeout = 5

[urgency_critical]
    background = "#1c1c1eb3"
    foreground = "#f5f5f7"
    frame_width = 1
    frame_color = "#66ff453a"
    timeout = 0

[hide_generic_app]
    appname = notify-send
    format = "<b>%s</b>\n<span foreground='#b0b0b8'>%b</span>"
